{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tlysanhuo/aminer-rec/schemas/recommend_and_dispatch.response.schema.json",
  "title": "RecommendAndDispatchResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "mode", "final_response"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "mode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "final_response": {
      "type": "string",
      "enum": ["NO_REPLY", "TEXT"]
    },
    "reply_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "backend_request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "result": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "final_response": { "const": "TEXT" }
        }
      },
      "then": {
        "required": ["reply_text"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "error" }
        }
      },
      "then": {
        "required": ["error"]
      }
    }
  ]
}
